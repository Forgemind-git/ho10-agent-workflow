{
  "mcpServers": {
    "morning-inputs-mcp": {
      "command": "node",
      "args": ["/path/to/morning-inputs-mcp/server.js"],
      "env": {
        "GOOGLE_CREDENTIALS_PATH": "${GOOGLE_CREDENTIALS_PATH}",
        "GOOGLE_TOKEN_PATH": "${GOOGLE_TOKEN_PATH}",
        "GMAIL_MAX_EMAILS": "10",
        "CALENDAR_HOURS_AHEAD": "24",
        "NEWS_TOPICS": "artificial intelligence,business,technology",
        "NEWS_MAX_ITEMS": "5",
        "NEWS_RSS_FEEDS": "https://feeds.feedburner.com/TechCrunch,https://feeds.reuters.com/reuters/businessNews",
        "EMAIL_IMPORTANCE_KEYWORDS": "urgent,deadline,action required,by today,ASAP",
        "CACHE_TTL_SECONDS": "300"
      },
      "description": "Fetches today's calendar events from Google Calendar, curated unread emails from Gmail, and relevant news headlines. Returns a structured inputs object ready for the Morning Brief Summariser skill.",
      "tools": [
        {
          "name": "get_morning_inputs",
          "description": "Fetch all morning briefing inputs: calendar events for today, top unread emails, and relevant news headlines",
          "inputSchema": {
            "type": "object",
            "properties": {
              "date": {
                "type": "string",
                "format": "date",
                "description": "Date to gather inputs for (YYYY-MM-DD). Defaults to today."
              },
              "gmail_max_emails": {
                "type": "integer",
                "description": "Maximum number of emails to include in the briefing",
                "default": 10
              },
              "gmail_label_filter": {
                "type": "string",
                "description": "Gmail label to filter emails by",
                "default": "INBOX"
              },
              "calendar_hours_ahead": {
                "type": "integer",
                "description": "Hours ahead to fetch calendar events for",
                "default": 24
              },
              "news_topics": {
                "type": "array",
                "items": { "type": "string" },
                "description": "Topics to filter news by for relevance",
                "default": ["business", "technology"]
              },
              "news_max_items": {
                "type": "integer",
                "description": "Maximum number of news items to include",
                "default": 5
              },
              "include_weather": {
                "type": "boolean",
                "description": "Include weather forecast if location is configured",
                "default": false
              }
            }
          },
          "outputSchema": {
            "type": "object",
            "properties": {
              "date": { "type": "string" },
              "day_of_week": { "type": "string" },
              "calendar": {
                "type": "object",
                "properties": {
                  "events": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "title": { "type": "string" },
                        "start": { "type": "string" },
                        "end": { "type": "string" },
                        "attendees": { "type": "array", "items": { "type": "string" } },
                        "meeting_link": { "type": "string" },
                        "notes": { "type": "string" }
                      }
                    }
                  },
                  "total_events": { "type": "integer" },
                  "free_blocks": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "start": { "type": "string" },
                        "end": { "type": "string" },
                        "duration_minutes": { "type": "integer" }
                      }
                    }
                  }
                }
              },
              "emails": {
                "type": "object",
                "properties": {
                  "unread_count": { "type": "integer" },
                  "top_emails": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "from": { "type": "string" },
                        "subject": { "type": "string" },
                        "preview": { "type": "string" },
                        "received_at": { "type": "string" },
                        "importance": { "type": "string", "enum": ["high", "medium", "low"] },
                        "requires_action": { "type": "boolean" },
                        "action_deadline": { "type": "string" }
                      }
                    }
                  }
                }
              },
              "news": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "headline": { "type": "string" },
                    "source": { "type": "string" },
                    "url": { "type": "string" },
                    "summary": { "type": "string" },
                    "relevance_score": { "type": "number" }
                  }
                }
              },
              "fetched_at": { "type": "string", "format": "date-time" }
            }
          }
        },
        {
          "name": "get_email_thread",
          "description": "Fetch the full thread for a specific email to get context for the brief",
          "inputSchema": {
            "type": "object",
            "properties": {
              "message_id": {
                "type": "string",
                "description": "Gmail message ID"
              }
            },
            "required": ["message_id"]
          }
        },
        {
          "name": "get_calendar_event_details",
          "description": "Fetch full details of a specific calendar event including notes and previous occurrences",
          "inputSchema": {
            "type": "object",
            "properties": {
              "event_id": {
                "type": "string",
                "description": "Google Calendar event ID"
              }
            },
            "required": ["event_id"]
          }
        }
      ]
    }
  }
}
