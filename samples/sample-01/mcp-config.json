{
  "mcpServers": {
    "trend-research-mcp": {
      "command": "node",
      "args": ["/path/to/trend-research-mcp/server.js"],
      "env": {
        "GOOGLE_TRENDS_RSS": "https://trends.google.com/trends/trendingsearches/daily/rss?geo=US",
        "HACKERNEWS_API": "https://hacker-news.firebaseio.com/v0",
        "RSS_FEEDS": "https://feeds.feedburner.com/TechCrunch,https://www.theverge.com/rss/index.xml",
        "MIN_RELEVANCE_SCORE": "0.7",
        "MAX_RESULTS": "5",
        "CACHE_TTL_SECONDS": "3600"
      },
      "description": "Fetches trending topics from Google Trends RSS and tech news RSS feeds. Returns ranked topic list with headlines, summaries, and relevance scores.",
      "tools": [
        {
          "name": "get_trending_topics",
          "description": "Fetch the top trending topics for a given industry or keyword from Google Trends and RSS news feeds",
          "inputSchema": {
            "type": "object",
            "properties": {
              "industry": {
                "type": "string",
                "description": "Industry or keyword to filter topics by (e.g. 'artificial intelligence', 'fintech', 'climate tech')"
              },
              "max_results": {
                "type": "integer",
                "description": "Maximum number of topics to return",
                "default": 5
              },
              "min_relevance_score": {
                "type": "number",
                "description": "Minimum relevance score (0.0 to 1.0) for a topic to be included",
                "default": 0.7
              },
              "sources": {
                "type": "array",
                "items": { "type": "string" },
                "description": "List of sources to fetch from: 'google_trends', 'hackernews', 'rss_feeds'",
                "default": ["google_trends", "hackernews", "rss_feeds"]
              }
            },
            "required": ["industry"]
          },
          "outputSchema": {
            "type": "object",
            "properties": {
              "topics": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "headline": { "type": "string" },
                    "summary": { "type": "string" },
                    "trend_score": { "type": "number" },
                    "source_url": { "type": "string" }
                  }
                }
              },
              "fetched_at": { "type": "string", "format": "date-time" }
            }
          }
        },
        {
          "name": "search_news",
          "description": "Search for recent news articles on a specific topic",
          "inputSchema": {
            "type": "object",
            "properties": {
              "query": {
                "type": "string",
                "description": "Search query string"
              },
              "days_back": {
                "type": "integer",
                "description": "How many days back to search",
                "default": 7
              },
              "max_results": {
                "type": "integer",
                "default": 10
              }
            },
            "required": ["query"]
          }
        }
      ]
    }
  }
}
